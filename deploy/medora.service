[Unit]
Description=Medora AI Inference Server
After=network.target

[Service]
User=root
Group=www-data
WorkingDirectory=/var/www/medora
Environment="PATH=/var/www/medora/venv/bin"
EnvironmentFile=/var/www/medora/.env
ExecStart=/var/www/medora/venv/bin/gunicorn -w 4 -k uvicorn.workers.UvicornWorker main:app --bind 0.0.0.0:8000

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
